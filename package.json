{
  "name": "grafana-updownio-datasource",
  "version": "1.0.0",
  "description": "Grafana plugin for UpDown.io datasource - Monitor your services status and visualize availability metrics",
  "author": {
    "name": "alo-is",
    "url": "https://github.com/alo-is"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/nextmap-io/grafana-updownio-datasource",
  "repository": {
    "type": "git",
    "url": "https://github.com/nextmap-io/grafana-updownio-datasource.git"
  },
  "bugs": {
    "url": "https://github.com/nextmap-io/grafana-updownio-datasource/issues"
  },
  "keywords": [
    "grafana",
    "plugin",
    "datasource",
    "updown",
    "updown.io",
    "monitoring",
    "uptime",
    "api"
  ],
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --ignore-path ./.gitignore --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "validate": "rm -rf tmp grafana-updownio-datasource.zip && mkdir -p tmp/updown-updownio-datasource && cp dist/*.json dist/*.md dist/LICENSE dist/module.js dist/go_plugin_build_manifest dist/gpx_updown_io_datasource_* tmp/updown-updownio-datasource/ && cp dist/img/logo.svg tmp/updown-updownio-datasource/ && cd tmp && zip -r ../grafana-updownio-datasource.zip updown-updownio-datasource/ -x '*.map' && cd .. && npx @grafana/plugin-validator@latest grafana-updownio-datasource.zip && rm -rf tmp",
    "package": "npm run build:all && rm -rf tmp grafana-updownio-datasource.zip && mkdir -p tmp/updown-updownio-datasource && cp dist/*.json dist/*.md dist/LICENSE dist/module.js dist/go_plugin_build_manifest dist/gpx_updown_io_datasource_* tmp/updown-updownio-datasource/ && if [ -f dist/img/logo.svg ]; then cp dist/img/logo.svg tmp/updown-updownio-datasource/; fi && cd tmp && zip -r ../grafana-updownio-datasource.zip updown-updownio-datasource/ -x '*.map' && cd .. && rm -rf tmp",
    "build:all": "npm run build && ~/go/bin/mage buildAll",
    "test:all": "npm run typecheck && npm run lint && npm run test:ci && npm run build:all && npm run validate",
    "e2e": "playwright test",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest"
  },
  "devDependencies": {
    "@grafana/eslint-config": "^8.2.0",
    "@grafana/plugin-e2e": "^2.1.13",
    "@grafana/tsconfig": "^2.0.0",
    "@playwright/test": "^1.52.0",
    "@stylistic/eslint-plugin-ts": "^2.9.0",
    "@swc/core": "^1.3.90",
    "@swc/helpers": "^0.5.0",
    "@swc/jest": "^0.2.26",
    "@testing-library/jest-dom": "6.1.4",
    "@testing-library/react": "14.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.8.7",
    "@types/testing-library__jest-dom": "5.14.8",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.7.3",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-jsdoc": "^46.8.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-webpack-plugin": "^4.0.1",
    "fork-ts-checker-webpack-plugin": "^8.0.0",
    "glob": "^10.2.7",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "prettier": "^2.8.7",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "1.63.2",
    "sass-loader": "13.3.1",
    "semver": "^7.6.3",
    "style-loader": "3.3.3",
    "swc-loader": "^0.2.3",
    "terser-webpack-plugin": "^5.3.10",
    "ts-node": "^10.9.2",
    "typescript": "5.5.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@emotion/css": "11.10.6",
    "@grafana/data": "^12.2.0",
    "@grafana/runtime": "^12.2.0",
    "@grafana/schema": "^12.2.0",
    "@grafana/ui": "^12.2.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "updown.io": "^3.3.5",
    "@grafana/i18n": "^12.2.0"
  },
  "packageManager": "npm@11.4.2"
}
